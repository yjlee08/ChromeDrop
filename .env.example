# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Required secrets ---
BOT_TOKEN=123456789:PASTE_YOUR_BOT_TOKEN_FROM_BOTFATHER
CHAT_ID=PASTE_YOUR_NUMERIC_TELEGRAM_CHAT_ID

# --- Fetch strategy: auto | requests | playwright ---
# auto = try requests, fall back to headless Playwright on a block/challenge.
FETCH_STRATEGY=auto
# In auto, only use Playwright for hard 403/challenge blocks (its real job).
# Leave false so a merely-empty page doesn't launch Chromium every sweep
# (saves CPU/heat). Set true only if a category is genuinely JS-only.
PLAYWRIGHT_ON_EMPTY=false

# --- Categories ---
# Discover categories from the site nav automatically (true/false).
DISCOVER_CATEGORIES=true
# Reuse the discovered category list this long (seconds) before re-scraping the
# homepage. Saves a fetch+parse every sweep; new categories still caught within.
DISCOVERY_TTL=3600
# Comma-separated fallback list used when discovery fails or is disabled.
STORE_URLS=https://www.chromehearts.com/socks,https://www.chromehearts.com/scents,https://www.chromehearts.com/baccarat,https://www.chromehearts.com/boxers-leggings,https://www.chromehearts.com/intimates

# --- Timing (be polite: keep CHECK_INTERVAL >= 60) ---
CHECK_INTERVAL=120
JITTER=30
PER_URL_DELAY=3
MAX_FETCH_RETRIES=4
BACKOFF_BASE=2

# --- Variable cadence (optional) ---
# Poll SLOW_INTERVAL seconds during SLOW_HOURS (when the store doesn't drop),
# and CHECK_INTERVAL the rest of the day (incl. the ~6am KST drop). Leave
# SLOW_HOURS empty to use CHECK_INTERVAL always. SLOW_HOURS is HH:MM-HH:MM in
# SLOW_TZ. Example: check every 10 min during 2pm-10pm Seoul, 2 min otherwise.
SLOW_HOURS=
SLOW_TZ=Asia/Seoul
SLOW_INTERVAL=600

# --- Filtering (optional) ---
# Comma-separated; only alert when a product title contains one of these.
KEYWORDS=

# --- State & logging ---
STATE_FILE=seen.json
LOG_FILE=ch_drop_bot.log

# --- Telegram throttling ---
TELEGRAM_MAX_ITEMS_PER_MSG=10
TELEGRAM_SEND_DELAY=1.2
# Retry a failed send this many times before giving up; a hit is only marked
# "seen" once delivered, so a failed alert re-fires next sweep (never lost).
TELEGRAM_SEND_RETRIES=3
TELEGRAM_RETRY_DELAY=3

# --- Telegram commands ---
# Reply to /status and /ping so you can check liveness from your phone.
COMMANDS_ENABLED=true
